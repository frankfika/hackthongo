# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# SMTP (optional - dev mode simulates emails when not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-pass
# EMAIL_FROM='"HackThonGo" <noreply@hackthongo.com>'

# Security (optional)
# TRUSTED_ORIGINS=https://yourdomain.com
# ALLOWED_ORIGINS=https://yourdomain.com
# ALLOWED_DOC_EMBED_HOSTS=docs.google.com,*.gitbook.io

# Seed (optional - defaults used in dev)
# SEED_ADMIN_PASSWORD=your-admin-password
# SEED_JUDGE_PASSWORD=your-judge-password
