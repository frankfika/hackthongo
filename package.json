{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:check": "node scripts/i18n-key-check.mjs",
    "test:e2e": "cypress run --spec \"cypress/e2e/*.cy.ts\" --browser electron",
    "test:security": "cypress run --spec cypress/e2e/security-hardening.cy.ts --browser electron",
    "test:overflow": "cypress run --spec cypress/e2e/overflow-guard.cy.ts,cypress/e2e/footer-responsive.cy.ts --browser electron",
    "security:burst": "node scripts/security-burst-test.mjs",
    "visual:reference": "backstop reference --config=backstop.config.cjs",
    "visual:test": "backstop test --config=backstop.config.cjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "prisma": "^6.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "backstopjs": "^6.3.25",
    "cypress": "^15.12.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
